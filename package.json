{
  "name": "ev-aftermarket",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "collect:reddit": "dotenv -e .env.local -- tsx scripts/collect-reddit.ts",
    "collect:reddit:dry": "dotenv -e .env.local -- tsx scripts/collect-reddit.ts --dry-run",
    "collect:reddit-api": "dotenv -e .env.local -- tsx scripts/collect-reddit-api.ts",
    "collect:reddit-api:dry": "dotenv -e .env.local -- tsx scripts/collect-reddit-api.ts --dry-run",
    "collect:charging": "dotenv -e .env.local -- tsx scripts/collect-charging-cases.ts",
    "collect:charging:dry": "dotenv -e .env.local -- tsx scripts/collect-charging-cases.ts --dry-run",
    "review": "dotenv -e .env.local -- tsx scripts/review-cases.ts",
    "review:list": "dotenv -e .env.local -- tsx scripts/review-cases.ts --list",
    "seed:warnings": "dotenv -e .env.local -- tsx scripts/seed-warning-lights.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@supabase/supabase-js": "^2.108.1",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "mysql2": "^3.22.3",
    "next": "16.2.6",
    "openai": "^6.39.1",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
